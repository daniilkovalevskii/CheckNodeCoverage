digraph G {
    root -> a -> b -> c -> d -> e;
    b -> f -> g -> h;
    f -> i -> j;
    i -> k;
    a -> l -> m -> n -> o;
    n -> p;
    n -> q;
    n -> r;
    root -> s -> t -> u;
    root -> v;
    root -> w;
    b -> x;
    e -> y;
    e -> z -> leaf1;
    p -> leaf2;
    v -> leaf3;
    w -> w1 -> w2 -> w3 -> w4 -> w5 -> leaf4;
    w2 -> leaf5;
    w5 -> leaf6;
    w -> leaf7;
    
    b[shape = diamond];
    k[shape = rectangle];
    g[shape = rectangle];
    c[shape = rectangle];
    
    j [color="orange", style="filled"];
    x [color="orange", style="filled"];
    c [color="green", style="filled"];
    g [color="green", style="filled"];
    k [color="green", style="filled"];
}